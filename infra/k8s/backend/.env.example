# Redis
REDIS_URL=redis://localhost:6379/0

# Postgres
DATABASE_URL=postgresql://consumeriq:consumeriq@localhost:5432/consumeriq

# ScrapingBee
# Optional: still used by Google SERP fallback paths.
SCRAPINGBEE_API_KEY=

# Bright Data
# Required for marketplace and social media collection.
BRIGHTDATA_API_TOKEN=

# OpenAI — required for Layer 2 dashboard generation and (when enabled) Cognee
# entity extraction. Falls back to BRIGHTDATA_API_TOKEN for the BrightData
# ChatGPT dataset path, but a real OpenAI key gives much better results.
OPENAI_API_KEY=

# Extra analysis. By default this uses Bright Data's ChatGPT dataset as a
# second-opinion source, then normalizes the result into the app schema.
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EXTRA_ANALYSIS_ENABLED=true
EXTRA_ANALYSIS_SOURCE=brightdata_chatgpt_dataset
BRIGHTDATA_CHATGPT_DATASET_ID=gd_m7aof0k82r803d5bjm
BRIGHTDATA_CHATGPT_SNAPSHOT_WAIT_SECONDS=600
OPENAI_TIMEOUT_SECONDS=60
OPENAI_BASE_URL=https://api.openai.com/v1

# Pipeline Bright Data guards.
PIPELINE_KEYWORD_LIMIT=6
PIPELINE_MAX_SIGNALS=50
PIPELINE_MARKETPLACE_RECORD_LIMIT=100
PIPELINE_SKIP_MARKETPLACES=lazada
PIPELINE_BRIGHTDATA_TIMEOUT_SECONDS=180
PIPELINE_SNAPSHOT_WAIT_SECONDS=600
PIPELINE_ALLOW_FALLBACK_SIGNALS=true

# Daily cron jobs. All default to "false" so dev runs don't burn credits.
# - DAILY_REFRESH_ENABLED: re-scrapes market signals for every user with a founder form
# - COMPLIANCE_SCRAPE_ENABLED: LLM generates 5 compliance/hazard keywords per user
#   (e.g. F&B → "FDA recall food", "food safety alert", ...) and scrapes them via SERP
# - SIGNAL_TTL_ENABLED: deletes marketSignals rows older than SIGNAL_TTL_MONTHS
# Flip each to "true" in production once you've created the consumeriq-admin Secret.
DAILY_REFRESH_ENABLED=false
COMPLIANCE_SCRAPE_ENABLED=false
SIGNAL_TTL_ENABLED=false
SIGNAL_TTL_MONTHS=4

# Recency weight added to the pgvector distance in _fetchRelevantSignals.
# Score = (embedding <-> query) + (CURRENT_DATE - signalDate) * SIGNAL_RECENCY_WEIGHT
# At 0.005: a 30-day-old signal pays +0.15, a 90-day-old +0.45.
SIGNAL_RECENCY_WEIGHT=0.005

# Admin endpoints (/api/admin/*) and CronJob curl calls require this header:
#   X-Admin-Token: $ADMIN_API_TOKEN
# Set the matching value in the consumeriq-admin Kubernetes Secret.
ADMIN_API_TOKEN=

# Cognee — persistent knowledge graph memory across workflows.
# When enabled, every scraped signal and every GPT-generated dashboard is
# pushed into a Cognee knowledge graph, and the ReAct agent gains a
# `memory_search` tool that queries the graph before issuing new scrapes.
# Default off so dev does not burn entity-extraction tokens.
COGNEE_ENABLED=false

# Cloud mode (default) — Cognee uses OpenAI for entity extraction + embeddings.
# Cheap (~$0.002 / 100 signals with gpt-4o-mini) but not free.
COGNEE_LLM_PROVIDER=openai
COGNEE_LLM_MODEL=gpt-4o-mini
COGNEE_EMBEDDING_MODEL=text-embedding-3-small
# Falls back to OPENAI_API_KEY if not set.
COGNEE_LLM_API_KEY=

# Local mode — point Cognee at our own Llama 3.2 3B + BGE-MiniLM containers
# (already OpenAI-compatible: llama-cpp-python serves /v1/chat/completions,
# inference/embeddings_server.py serves /v1/embeddings).
# Zero per-call cost, fully private. Trade-off: Llama 3.2 3B does weaker
# entity extraction than gpt-4o-mini, so the graph is shallower.
COGNEE_USE_LOCAL_INFERENCE=false
COGNEE_LOCAL_LLM_URL=http://consumeriq-inference.consumeriq.svc.cluster.local:8080/v1
COGNEE_LOCAL_LLM_MODEL=llama-3.2-3b
COGNEE_LOCAL_EMBEDDING_URL=http://consumeriq-embeddings.consumeriq.svc.cluster.local:8080/v1
COGNEE_LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
COGNEE_LOCAL_EMBEDDING_DIMS=384

# Go service
REDIS_ADDR=localhost:6379
PORT=8080
PYTHON_API_URL=http://localhost:8000

# Backpressure — set to "true" on 4-vCPU prod to cap inference queue
# Leave "false" for local dev (no queue depth gates)
BACKPRESSURE_ENABLED=false

# Max concurrent LLM inference tasks in the Celery worker
# Raise for local dev, keep at 1 for prod (memory-bound)
INFERENCE_CONCURRENCY=2

# Max inference queue depth before /api/agent/run and /api/persona-decode reject (503)
# Only enforced when BACKPRESSURE_ENABLED=true
INFERENCE_QUEUE_LIMIT=20
