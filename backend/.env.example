# https://brightdata.com
BRIGHTDATA_API_TOKEN=

OPENAI_MODEL=gpt-5.4-mini

OPENAI_EXTRA_ANALYSIS_ENABLED=true
EXTRA_ANALYSIS_SOURCE=brightdata_chatgpt_dataset
BRIGHTDATA_CHATGPT_DATASET_ID=gd_m7aof0k82r803d5bjm
BRIGHTDATA_CHATGPT_SNAPSHOT_WAIT_SECONDS=600
